{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":maintainLockFilesWeekly",
    ":enableVulnerabilityAlerts"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "🚨 Security vulnerabilities (OSV/GitHub alerts)",
      "matchManagers": [
        "npm",
        "pnpm",
        "yarn",
        "pip_requirements",
        "composer",
        "mix"
      ],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "vulnerabilityFixVersion": true,
      "groupName": null,
      "prPriority": 100,
      "labels": ["security", "osv"],
      "commitMessageSuffix": "[SECURITY]",
      "branchTopic": "security-{{depName}}"
    },
    {
      "description": "Group all non-major devDependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "devDependencies (non-major)"
    },
    {
      "description": "Group TypeScript type definitions",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "TypeScript type definitions"
    },
    {
      "description": "Group ESLint related packages",
      "matchPackagePatterns": ["eslint"],
      "groupName": "ESLint"
    },
    {
      "description": "Python dependencies",
      "matchManagers": ["pip_requirements", "pep621", "pip-compile"],
      "groupName": "Python dependencies"
    },
    {
      "description": "PHP dependencies",
      "matchManagers": ["composer"],
      "groupName": "PHP dependencies"
    },
    {
      "description": "Elixir dependencies",
      "matchManagers": ["mix"],
      "groupName": "Elixir dependencies"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "osv"]
  },
  "osvVulnerabilityAlerts": true,
  "prCreation": "immediate",
  "schedule": ["before 9am on monday"]
}
